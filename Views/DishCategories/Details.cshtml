@model KTGIUAKY.Models.DishCategory_BCS240047

@{
    ViewData["Title"] = "Chi tiết loại món ăn";
}

<h1>Chi tiết loại món ăn</h1>

<div>
    <h4>@Model.Name</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Tên loại</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Mô tả</dt>
        <dd class="col-sm-9">@(Model.Description ?? "Không có mô tả")</dd>

        <dt class="col-sm-3">Số món ăn</dt>
        <dd class="col-sm-9">@Model.Dishes?.Count</dd>
    </dl>
</div>

@if (Model.Dishes != null && Model.Dishes.Any())
{
    <h4>Danh sách món ăn thuộc loại này</h4>
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Tên món</th>
                <th>Giá</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dish in Model.Dishes)
            {
                <tr>
                    <td><a asp-controller="Dishes" asp-action="Details" asp-route-id="@dish.Id">@dish.Name</a></td>
                    <td>@dish.Price.ToString("#,##0") đ</td>
                    <td>
                        @if (dish.IsAvailable)
                        {
                            <span class="badge bg-success">Đang bán</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Ngừng bán</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Chưa có món ăn nào thuộc loại này.</p>
}

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>
