@model IEnumerable<KTGIUAKY.Models.Dish_BCS240047>

@{
    ViewData["Title"] = "Danh sách món ăn";
}

<h1>Danh sách món ăn</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm món ăn mới</a>
    <a asp-controller="DishCategories" asp-action="Index" class="btn btn-secondary">Quản lý loại món ăn</a>
</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-3">
            <input type="text" name="searchString" class="form-control" placeholder="Tìm kiếm theo tên..." value="@ViewBag.SearchString" />
        </div>
        <div class="col-md-2">
            <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
                <option value="">-- Tất cả loại --</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="isAvailable" class="form-select">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="true" selected="@(ViewBag.IsAvailable == true)">Đang bán</option>
                <option value="false" selected="@(ViewBag.IsAvailable == false)">Ngừng bán</option>
            </select>
        </div>
        <div class="col-md-1">
            <input type="number" name="minPrice" class="form-control" placeholder="Giá từ" value="@ViewBag.MinPrice" step="1000" />
        </div>
        <div class="col-md-1">
            <input type="number" name="maxPrice" class="form-control" placeholder="Giá đến" value="@ViewBag.MaxPrice" step="1000" />
        </div>
        <div class="col-md-1">
            <select name="sortOrder" class="form-select">
                <option value="">Mặc định</option>
                <option value="price_asc" selected="@(ViewBag.SortOrder == "price_asc")">Giá tăng dần</option>
                <option value="price_desc" selected="@(ViewBag.SortOrder == "price_desc")">Giá giảm dần</option>
                <option value="time_asc" selected="@(ViewBag.SortOrder == "time_asc")">TG chế biến tăng</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
        </div>
    </div>
</form>

@if (ViewBag.PriceError != null)
{
    <div class="alert alert-warning">@ViewBag.PriceError</div>
}

@if (ViewBag.NoResults != null)
{
    <div class="alert alert-info">@ViewBag.NoResults</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Ảnh</th>
            <th>Tên món ăn</th>
            <th>Loại</th>
            <th>Giá</th>
            <th>Thời gian chế biến</th>
            <th>Phân loại</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var thumbnail = item.DishImages?.FirstOrDefault(i => i.IsThumbnail);
            <tr class="@(item.IsAvailable ? "" : "table-secondary")">
                <td>
                    @if (thumbnail != null)
                    {
                        <img src="@thumbnail.ImageUrl" alt="@item.Name" style="width: 60px; height: 60px; object-fit: cover;" />
                    }
                    else
                    {
                        <span class="text-muted">Chưa có ảnh</span>
                    }
                </td>
                <td>@item.Name</td>
                <td>@item.DishCategory?.Name</td>
                <td>@item.Price.ToString("#,##0") đ</td>
                <td>@item.PreparationTime phút</td>
                <td>
                    @if (item.PreparationTime <= 15)
                    {
                        <span class="badge bg-success">Nhanh</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Thông thường</span>
                    }
                </td>
                <td>
                    @if (item.IsAvailable)
                    {
                        <span class="badge bg-success">Đang bán</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Ngừng bán</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
