@model KTGIUAKY.Models.DishImage_BCS240047

@{
    ViewData["Title"] = "Thêm ảnh";
}

<h1>Thêm ảnh cho món ăn</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="DishId" />

            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="Nhập đường dẫn ảnh" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
                <div class="form-text">Ví dụ: https://via.placeholder.com/300x200</div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsThumbnail" class="form-check-input" />
                <label asp-for="IsThumbnail" class="form-check-label"></label>
            </div>

            <div class="mb-3">
                <input type="submit" value="Thêm ảnh" class="btn btn-primary" />
                <a asp-controller="Dishes" asp-action="Details" asp-route-id="@Model.DishId" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
